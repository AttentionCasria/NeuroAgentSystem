<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.it.mapper.LoginMapper">

    <select id="findUser" resultType="com.it.pojo.User">
        select u.id,u.name,u.image from user u where name=#{name} and password=#{password}
    </select>
    <select id="findUserByName" resultType="com.it.pojo.User">
        select * from user where name = #{name}
    </select>
</mapper>